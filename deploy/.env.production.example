# Smart Story (หมีอ่าน) — production environment.
# Copy to ".env.production" on the Windows server and fill in real values.
# This file is read by ecosystem.config.js and passed to the Next.js server.

# ----- Database (MySQL on the Windows server) -----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=smartstory
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=smart_story_ai

# ----- Sign-in token audiences (verified by /api/auth via jose) -----
# Must match the OAuth client IDs the mobile app uses.
GOOGLE_CLIENT_IDS=969332035032-flh19bqg1mbeeem2599nuehblsev20vt.apps.googleusercontent.com
APPLE_CLIENT_IDS=com.gooddayinnovation.smartStory

# ----- Content generation (OPTIONAL on production) -----
# Only needed if you generate NEW stories on this server. Serving existing
# stories to the mobile app does NOT require these. Leave blank to disable.
GEMINI_API_KEY=
# PYTHON=
# SUT_STORY_SCRIPT=
